generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  customer
  seller
  godown
  delivery
  admin
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PACKED
  READY_FOR_PICKUP
  DISPATCHED
  PICKED_UP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentReceiverType {
  platform
  godown
  seller
}

model User {
  id          String   @id @default(cuid())
  name        String
  phone       String?  @unique
  email       String?  @unique
  role        UserRole @default(customer)
  refundUpiId String?
  createdAt   DateTime @default(now())

  sellerProfile Seller?
  customerOrders Order[] @relation("CustomerOrders")
  statusChanges  OrderStatusHistory[] @relation("StatusChangedBy")
}

model Seller {
  id         String  @id @default(cuid())
  userId     String  @unique
  shopName   String
  sellerUpiId String?
  address    String
  isVerified Boolean @default(false)

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
  orderItems OrderItem[]
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  sellerId    String
  title       String
  description String?
  price       Decimal  @db.Decimal(12, 2)
  stock       Int
  images      Json
  categoryId  String
  isActive    Boolean  @default(true)

  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category  Category @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  label     String?
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String

  orders    Order[]
}

model Order {
  id                  String              @id @default(cuid())
  customerId          String
  status              OrderStatus         @default(PENDING)
  totalAmount         Decimal             @db.Decimal(12, 2)
  paymentStatus       PaymentStatus       @default(PENDING)
  paymentReceiverType PaymentReceiverType
  receiverUpiId       String?
  addressId           String
  createdAt           DateTime            @default(now())

  customer      User                 @relation("CustomerOrders", fields: [customerId], references: [id])
  address       Address              @relation(fields: [addressId], references: [id])
  items         OrderItem[]
  statusHistory OrderStatusHistory[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  sellerId  String
  qty       Int
  price     Decimal @db.Decimal(12, 2)

  order    Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product  Product @relation(fields: [productId], references: [id])
  seller   Seller  @relation(fields: [sellerId], references: [id])
}

model OrderStatusHistory {
  id              String      @id @default(cuid())
  orderId         String
  status          OrderStatus
  changedByUserId String
  changedAt       DateTime    @default(now())

  order         Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedByUser User  @relation("StatusChangedBy", fields: [changedByUserId], references: [id])
}
