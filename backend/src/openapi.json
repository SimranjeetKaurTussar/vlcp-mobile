{
  "openapi": "3.0.0",
  "info": { "title": "VLCP API", "version": "1.0.0" },
  "servers": [{ "url": "http://localhost:4000" }],

  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },

  "security": [{ "BearerAuth": [] }],

  "paths": {
    "/health": {
      "get": { "summary": "Health check", "responses": { "200": { "description": "OK" } } }
    },
    "/auth/login": {
      "post": {
        "summary": "Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Login success" } }
      }
    },
    "/products": {
      "get": { "summary": "Get products", "responses": { "200": { "description": "OK" } } }
    },
    "/orders": {
      "get": { "summary": "Get orders", "responses": { "200": { "description": "OK" } } }
    }
  }
}